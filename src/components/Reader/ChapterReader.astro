</style>

<script is:inline>
    function initReader() {
        const container = document.getElementById('reader-container');
        const content = document.getElementById('reading-content');
        const dataEl = document.getElementById('reader-data');
        if (!container || !content) return;

        const header = document.getElementById('global-header');
        const toolbar = document.getElementById('reader-toolbar');

        if (header) {
            header.dataset.allowAutoHide = 'true';
            header.classList.add('reader-nav-auto');
        }
        if (toolbar) {
            toolbar.classList.add('reader-toolbar-auto');
        }

        let lastScrollY = window.scrollY;
        let navHeight = header ? header.offsetHeight : 0;
        let toolbarBaseOffset = 0;
        let navOffset = 0;

        const clamp = (value, min, max) => Math.min(Math.max(value, min), max);
        const measureToolbarTop = () => {
            if (!toolbar) return navHeight || 64;
            const inlineValue = toolbar.style.getPropertyValue('--reader-toolbar-offset');
            const hadInline = inlineValue !== '';
            if (hadInline) {
                toolbar.style.removeProperty('--reader-toolbar-offset');
            }
            const computedTop = parseFloat(window.getComputedStyle(toolbar).top);
            if (hadInline) {
                toolbar.style.setProperty('--reader-toolbar-offset', inlineValue);
            }
            return Number.isFinite(computedTop) ? computedTop : (navHeight || 64);
        };
        const updateMetrics = () => {
            if (header) {
                navHeight = header.offsetHeight || navHeight;
            }
            const fallback = navHeight || 64;
            const measuredTop = measureToolbarTop();
            toolbarBaseOffset = Math.max(measuredTop, fallback);
            navOffset = clamp(navOffset, 0, toolbarBaseOffset);
            applyPositions();
        };
        const applyPositions = () => {
            const travel = toolbarBaseOffset || navHeight || 64;
            const offset = clamp(navOffset, 0, travel);
            if (header) {
                header.style.transform = `translateY(${-offset}px)`;
            }
            if (toolbar) {
                const remaining = Math.max(toolbarBaseOffset - offset, 0);
                toolbar.style.setProperty('--reader-toolbar-offset', `${remaining}px`);
                toolbar.classList.toggle('reader-toolbar-pinned', remaining <= 1);
            }
        };
        updateMetrics();

        const syncPositions = (currentY) => {
            const isImmersive = localStorage.getItem('reader-immersion') === 'true';
            const travel = toolbarBaseOffset || navHeight || 64;
            if (isImmersive) {
                navOffset = travel;
                applyPositions();
                lastScrollY = currentY;
                return;
            }

            const delta = currentY - lastScrollY;
            if (currentY < 20) {
                navOffset = 0;
            } else if (delta > 1) {
                navOffset = clamp(navOffset + delta, 0, travel);
            } else if (delta < -1) {
                navOffset = clamp(navOffset + delta, 0, travel);
            }

            applyPositions();
            lastScrollY = currentY;
        };

        const handleScroll = () => {
            syncPositions(window.scrollY);
        };
        const handleResize = () => {
            updateMetrics();
            lastScrollY = window.scrollY;
        };
        const handleVisibility = () => {
            if (document.visibilityState === 'visible') {
                lastScrollY = window.scrollY;
                applyPositions();
            }
        };

        window.addEventListener('scroll', handleScroll, { passive: true });
        window.addEventListener('resize', handleResize);
        document.addEventListener('visibilitychange', handleVisibility);
        syncPositions(window.scrollY);
        document.addEventListener('astro:before-preparation', () => {
            window.removeEventListener('scroll', handleScroll);
            window.removeEventListener('resize', handleResize);
            document.removeEventListener('visibilitychange', handleVisibility);
            if (header) {
                header.classList.remove('reader-nav-auto', 'reader-nav-hidden');
                header.style.transform = '';
                delete header.dataset.allowAutoHide;
            }
            if (toolbar) {
                toolbar.classList.remove('reader-toolbar-auto', 'reader-toolbar-pinned');
                toolbar.style.removeProperty('--reader-toolbar-offset');
            }
        });

        const ua = navigator.userAgent || '';
        const isChromeWindows = ua.includes('Windows') && ua.includes('Chrome') && !ua.includes('Edg') && !ua.includes('OPR');
        if (isChromeWindows) {
            container.classList.add('chrome-reading-mode');
        }

    // --- 1. CUSTOM DROPDOWN ENGINE ---
    function setupCustomDropdown(dropdownId, onChange) {
        const dropdown = document.getElementById(dropdownId);
        if (!dropdown) return { setValue: () => {} };
        const trigger = dropdown.querySelector('.dropdown-trigger');
        const menu = dropdown.querySelector('.dropdown-menu');
        const opts = Array.from(dropdown.querySelectorAll('.dropdown-opt'));
        if (!trigger || !menu || opts.length === 0) return { setValue: () => {} };
        const triggerDot = trigger.querySelector('.dot');
        const triggerLabel = trigger.querySelector('.trigger-label');

        const applyVisuals = (opt) => {
            if (!opt) return;
            if (triggerDot) {
                const sample = opt.querySelector('.dot, span, div');
                if (sample) {
                    const dotColor = window.getComputedStyle(sample).backgroundColor;
                    if (dotColor) triggerDot.style.backgroundColor = dotColor;
                }
            }
            if (triggerLabel) {
                triggerLabel.textContent = opt.dataset.label || opt.textContent.trim();
            }
            opts.forEach(option => option.classList.toggle('active', option === opt));
        };

        const commit = (val) => {
            const opt = opts.find(o => o.dataset.value === val);
            if (!opt) return;
            onChange(val);
            applyVisuals(opt);
        };

        trigger.onclick = (e) => { e.stopPropagation(); menu.classList.toggle('hidden'); };
        document.addEventListener('click', () => menu.classList.add('hidden'));
        opts.forEach(opt => {
            opt.onclick = () => {
                commit(opt.dataset.value);
                menu.classList.add('hidden');
            };
        });
        return { setValue: (val) => { const opt = opts.find(o => o.dataset.value === val); applyVisuals(opt); } };
    }

    // --- 2. THEMES & TYPOGRAPHY ---
    const themeDD = setupCustomDropdown('theme-dropdown', (v) => {
        container.className = `min-h-screen transition-colors duration-500 pt-10 pb-32 theme-${v} w-full`;
        localStorage.setItem('reader-theme', v);
    });
    const savedTheme = localStorage.getItem('reader-theme') || 'void';
    themeDD.setValue(savedTheme);
    container.className = `min-h-screen transition-colors duration-500 pt-10 pb-32 theme-${savedTheme} w-full`;

    // Micro panel toggles
    const fontPanelButtons = Array.from(document.querySelectorAll('#font-controls [data-panel-target]'));
    let openPanel = null;
    let openButton = null;
    const closePanels = () => {
        if (openPanel && openButton) {
            openPanel.classList.add('hidden');
            openButton.classList.remove('active');
        }
        openPanel = null;
        openButton = null;
    };
    fontPanelButtons.forEach(btn => {
        const targetId = btn.getAttribute('data-panel-target');
        const panel = targetId ? document.getElementById(targetId) : null;
        if (!panel) return;
        panel.addEventListener('click', (e) => e.stopPropagation());
        btn.addEventListener('click', (e) => {
            e.stopPropagation();
            if (openPanel && openPanel !== panel) closePanels();
            const willOpen = panel.classList.contains('hidden');
            if (willOpen) {
                panel.classList.remove('hidden');
                btn.classList.add('active');
                openPanel = panel;
                openButton = btn;
            } else {
                closePanels();
            }
        });
    });
    document.addEventListener('click', closePanels);

    // Font families
    const familyOptions = Array.from(document.querySelectorAll('[data-font-value]'));
    const familyLabel = document.getElementById('font-family-label');
    const applyFamily = (value, label) => {
        content.style.fontFamily = value;
        localStorage.setItem('reader-font-family', value);
        if (familyLabel) familyLabel.textContent = label || 'Serif';
        familyOptions.forEach(opt => opt.classList.toggle('active', opt.dataset.fontValue === value));
    };
    const savedFamily = localStorage.getItem('reader-font-family') || 'inherit';
    const savedFamilyLabel = familyOptions.find(opt => opt.dataset.fontValue === savedFamily)?.dataset.label || 'Serif';
    applyFamily(savedFamily, savedFamilyLabel);
    familyOptions.forEach(opt => {
        opt.addEventListener('click', () => {
            applyFamily(opt.dataset.fontValue || 'inherit', opt.dataset.label || opt.textContent.trim());
        });
    });

    // Ink colors
    const inkOptions = Array.from(document.querySelectorAll('[data-ink-value]'));
    const inkDot = document.getElementById('ink-trigger-dot');
    const inkLabel = document.getElementById('ink-label');
    const applyInk = (value, label) => {
        container.style.setProperty('--reader-ink', value);
        content.style.color = value;
        localStorage.setItem('reader-font-color', value);
        if (inkDot) inkDot.style.backgroundColor = value;
        if (inkLabel) inkLabel.textContent = label || 'Ink';
        inkOptions.forEach(opt => opt.classList.toggle('active', opt.dataset.inkValue === value));
    };
    const savedInk = localStorage.getItem('reader-font-color') || '#e1e1e1';
    const savedInkLabel = inkOptions.find(opt => opt.dataset.inkValue === savedInk)?.dataset.label || 'Bone';
    applyInk(savedInk, savedInkLabel);
    inkOptions.forEach(opt => {
        opt.addEventListener('click', () => {
            const newValue = opt.dataset.inkValue || savedInk;
            const newLabel = opt.dataset.label || opt.textContent.trim();
            applyInk(newValue, newLabel);
        });
    });

    setupCustomDropdown('voice-dropdown', () => {}); // Just for trigger/close logic

    // --- 3. BARS TOGGLE ---
    const fBT = document.getElementById('font-bar-toggle');
    const fC = document.getElementById('font-controls');
    const vT = document.getElementById('voice-toggle');
    const vC = document.getElementById('voice-controls');

    if (fBT) fBT.onclick = () => { 
        fC.classList.toggle('hidden'); 
        fBT.style.color = fC.classList.contains('hidden') ? '' : 'var(--accent)';
        vC?.classList.add('hidden'); 
        if (vT) vT.style.color = '';
    };

    if (vT) vT.onclick = () => { 
        vC?.classList.toggle('hidden'); 
        vT.style.color = vC.classList.contains('hidden') ? '' : 'var(--accent)';
        fC?.classList.add('hidden'); 
        if (fBT) fBT.style.color = '';
    };

    // --- 4. SIZE ---
    let fontSize = parseInt(localStorage.getItem('reader-font-size')) || 18;
    const sVD = document.getElementById('font-size-val');
    const updateFS = (s) => {
        fontSize = s; content.style.fontSize = s + 'px';
        if (sVD) sVD.innerText = s;
        localStorage.setItem('reader-font-size', s);
    };
    [document.getElementById('font-inc-main'), document.getElementById('font-inc-alt')].forEach(b => b && (b.onclick = () => updateFS(fontSize + 2)));
    [document.getElementById('font-dec-main'), document.getElementById('font-dec-alt')].forEach(b => b && (b.onclick = () => fontSize > 12 && updateFS(fontSize - 2)));
    updateFS(fontSize);

    // Line height control
    let lineHeight = parseFloat(localStorage.getItem('reader-line-height'));
    if (!lineHeight || Number.isNaN(lineHeight)) lineHeight = 1.8;
    const lineSlider = document.getElementById('line-height-slider');
    const lineDisplay = document.getElementById('line-height-val');
    const updateLineHeight = (value) => {
        const normalized = Math.min(2.4, Math.max(1.2, value));
        lineHeight = normalized;
        if (content) content.style.lineHeight = normalized.toString();
        if (lineDisplay) lineDisplay.innerText = normalized.toFixed(2);
        localStorage.setItem('reader-line-height', normalized.toString());
        if (lineSlider && parseFloat(lineSlider.value) !== normalized) lineSlider.value = normalized.toString();
    };
    if (lineSlider) {
        lineSlider.value = lineHeight.toString();
        lineSlider.addEventListener('input', (e) => updateLineHeight(parseFloat(e.target.value)));
    }
    updateLineHeight(lineHeight);

    // Letter spacing control
    let letterSpacing = parseFloat(localStorage.getItem('reader-letter-spacing'));
    if (Number.isNaN(letterSpacing)) letterSpacing = 0;
    const spacingSlider = document.getElementById('letter-spacing-slider');
    const spacingDisplay = document.getElementById('letter-spacing-val');
    const updateLetterSpacing = (value) => {
        const normalized = Math.min(0.12, Math.max(0, value));
        letterSpacing = normalized;
        if (content) content.style.letterSpacing = `${normalized}em`;
        if (spacingDisplay) {
            const clean = normalized.toFixed(3).replace(/0+$/, '').replace(/\.$/, '');
            spacingDisplay.innerText = `${clean || '0'}em`;
        }
        localStorage.setItem('reader-letter-spacing', normalized.toString());
        if (spacingSlider && parseFloat(spacingSlider.value) !== normalized) spacingSlider.value = normalized.toString();
    };
    if (spacingSlider) {
        spacingSlider.value = letterSpacing.toString();
        spacingSlider.addEventListener('input', (e) => updateLetterSpacing(parseFloat(e.target.value)));
    }
    updateLetterSpacing(letterSpacing);

    // --- 5. FULLSCREEN ---
    const fsT = document.getElementById('fullscreen-toggle');
    const gH = document.getElementById('global-header');
    const sB = document.getElementById('sect-seal-btn');
    const rT = document.getElementById('reader-toolbar');
    const eI = document.getElementById('expand-icon');
    const sI = document.getElementById('shrink-icon');

    const toggleUI = (show) => {
      // Signals: show === true (Fake OUT / Normal), show === false (Fake ON / Immersive)
      if (gH) gH.style.setProperty('display', show ? 'flex' : 'none', 'important');
      if (sB) sB.style.setProperty('display', show ? 'flex' : 'none', 'important');
      if (rT) {
          if (show) {
              navOffset = clamp(navOffset, 0, toolbarBaseOffset);
          } else {
              navOffset = toolbarBaseOffset;
          }
          applyPositions();
          rT.style.borderRadius = show ? '0.5rem' : '0px';
      }
      if (eI) eI.classList.toggle('hidden', !show);
      if (sI) sI.classList.toggle('hidden', show);
      
      // Apply Signal to Button Color & Border
      if (fsT) {
          fsT.style.color = show ? '' : 'var(--accent)';
          fsT.style.borderColor = show ? '' : 'var(--accent)';
      }
      
      localStorage.setItem('reader-immersion', show ? 'false' : 'true');
    };

    if (fsT) {
        fsT.onclick = () => {
            const isSimulated = localStorage.getItem('reader-immersion') === 'true';
            
            if (document.fullscreenElement) {
                // 1. Normal OFF (Native -> Normal)
                document.exitFullscreen();
                toggleUI(true);
            } else if (isSimulated) {
                // 2. Fake OUT (Simulated -> Normal)
                toggleUI(true);
            } else {
                // 3. Normal ON (Normal -> Native + Visual)
                document.documentElement.requestFullscreen()
                    .then(() => toggleUI(false))
                    .catch(() => toggleUI(false)); // Fallback to visual
            }
        };
    }
    
    document.addEventListener('fullscreenchange', () => { 
        if (!document.fullscreenElement) {
            // Restore UI if system-level exit (Esc)
            toggleUI(true); 
        }
    });

    // Restore Immersion State (Fake ON Signal)
    const savedImmersion = localStorage.getItem('reader-immersion') === 'true';
    if (savedImmersion) {
        toggleUI(false);
    }

    // --- 6. CELESTIAL VOICE ENGINE (TTS) ---
    class CelestialVoice {
        constructor() {
            this.synth = window.speechSynthesis;
            this.words = [];
            this.pointer = 0;
            this.selectedIdx = null;
            this.isPlaying = false;
            this.isPaused = false;
            this.utterance = null;
            this.nextUtterance = null;
            const ua = typeof navigator !== 'undefined' ? navigator.userAgent || '' : '';
            const isChrome = ua.includes('Chrome') && !ua.includes('Edg') && !ua.includes('OPR');
            this.isChromeWindows = isChrome && ua.includes('Windows');
            this.isChromeAndroid = isChrome && ua.includes('Android');
            this.activeParagraph = null;
            this.androidWordPointer = 0;

            // Performance + sync helpers
            this.activeIdx = null;
            this.lastScrollAt = 0;

            // Boundary support + fallback highlighter (some Chrome voices don't emit word boundaries)
            this.boundaryEventsSeen = 0;
            this.fallbackGuardTimer = null;
            this.fallbackTimers = [];
            this.currentChunkIndices = null;
            
            this.playBtn = document.getElementById('voice-play');
            this.pauseBtn = document.getElementById('voice-pause');
            this.restartBtn = document.getElementById('voice-restart');
            this.speedSlider = document.getElementById('voice-speed-slider');
            this.speedTrigger = document.getElementById('speed-trigger');
            this.speedContainer = document.getElementById('speed-slider-container');
            this.speedPreview = document.getElementById('speed-preview');

            this.init();
        }

        init() {
            this.tokenize();
            this.loadVoices();
            if (this.synth.onvoiceschanged !== undefined) {
                this.synth.onvoiceschanged = () => this.loadVoices();
            }

            this.playBtn.onclick = () => this.play();
            this.pauseBtn.onclick = () => this.pause();
            this.restartBtn.onclick = () => this.restart();
            
            // Speed Slider Logic
            if (this.speedTrigger) {
                this.speedTrigger.onclick = (e) => {
                    e.stopPropagation();
                    this.speedContainer.classList.toggle('hidden');
                };
            }

            if (this.speedSlider) {
                this.speedSlider.oninput = () => {
                    const val = `${parseFloat(this.speedSlider.value).toFixed(1)}x`;
                    this.speedTrigger.innerText = val;
                    this.speedPreview.innerText = val;
                };
                this.speedSlider.onchange = () => {
                    this.speedContainer.classList.add('hidden');
                };
            }

            document.addEventListener('click', () => this.speedContainer?.classList.add('hidden'));
            this.speedContainer?.addEventListener('click', (e) => e.stopPropagation());
            
            // Two-step Pointer System
            this.words.forEach(span => {
                span.addEventListener('click', (e) => {
                    const idx = parseInt(span.dataset.index);
                    if (this.selectedIdx === idx) {
                        // Second click on same word: Move Reading Pointer
                        this.jumpTo(idx);
                        this.selectedIdx = null;
                        this.updateFocusUI();
                    } else {
                        // First click: Selection/Brightness only
                        this.selectedIdx = idx;
                        this.updateFocusUI();
                    }
                });
            });
        }

        updateFocusUI() {
            this.words.forEach(w => w.classList.remove('focus-word'));
            if (this.selectedIdx !== null && this.words[this.selectedIdx]) {
                this.words[this.selectedIdx].classList.add('focus-word');
            }
        }

        tokenize() {
            const payload = document.getElementById('content-payload');
            if (!payload) return;
            
            // We walk through all text nodes and wrap words in spans
            const walker = document.createTreeWalker(payload, NodeFilter.SHOW_TEXT, null, false);
            const nodes = [];
            while(walker.nextNode()) nodes.push(walker.currentNode);

            let globalIdx = 0;
            nodes.forEach(node => {
                const text = node.nodeValue;
                const words = text.split(/(\s+)/); // Keep whitespace
                const fragment = document.createDocumentFragment();

                words.forEach(word => {
                    if (word.trim().length > 0) {
                        const span = document.createElement('span');
                        span.className = 'reading-word transition-colors duration-150 cursor-pointer hover:text-gold/80';
                        span.dataset.index = globalIdx;
                        span.textContent = word;
                        fragment.appendChild(span);
                        this.words.push(span);
                        globalIdx++;
                    } else {
                        fragment.appendChild(document.createTextNode(word));
                    }
                });
                node.parentNode.replaceChild(fragment, node);
            });
        }

        loadVoices() {
            const voices = this.synth.getVoices();
            const container = document.getElementById('voice-select-container');
            if (!container) return;
            
            // Prioritize American English (en-US)
            const usVoice = voices.find(v => v.lang === 'en-US' || v.lang === 'en_US') || 
                            voices.find(v => v.lang.startsWith('en'));
            
            if (usVoice && !this.selectedVoiceName) {
                this.selectedVoiceName = usVoice.name;
            } else if (voices.length > 0 && !this.selectedVoiceName) {
                this.selectedVoiceName = voices[0].name;
            }

            container.textContent = '';
            voices.forEach(v => {
                const isSelected = this.selectedVoiceName === v.name;
                const btn = document.createElement('button');
                btn.className = `w-full flex items-center gap-3 px-3 py-2 hover:bg-gold/10 text-[10px] ${isSelected ? 'text-gold bg-gold/5' : 'text-gold/60'} uppercase rounded-lg text-left transition-all`;
                const dot = document.createElement('span');
                dot.className = `w-1.5 h-1.5 rounded-full ${isSelected ? 'bg-gold shadow-[0_0_5px_rgba(197,160,89,0.5)]' : 'bg-gold/20'}`;
                btn.appendChild(dot);
                btn.appendChild(document.createTextNode(` ${v.name}`));
                btn.onclick = () => {
                    this.selectedVoiceName = v.name;
                    container.querySelectorAll('button').forEach(b => {
                        b.classList.replace('text-gold', 'text-gold/60');
                        b.classList.remove('bg-gold/5');
                        const indicator = b.querySelector('span');
                        if (indicator) {
                            indicator.classList.replace('bg-gold', 'bg-gold/20');
                        }
                    });
                    btn.classList.replace('text-gold/60', 'text-gold');
                    btn.classList.add('bg-gold/5');
                    const indicator = btn.querySelector('span');
                    if (indicator) {
                        indicator.classList.replace('bg-gold/20', 'bg-gold');
                    }
                };
                container.appendChild(btn);
            });
        }

        updateUI(playing) {
            this.isPlaying = playing;
            this.playBtn.classList.toggle('hidden', playing);
            this.pauseBtn.classList.toggle('hidden', !playing);
        }

        highlight(index) {
            // Fast highlight: only touch the previous + current word (O(1) instead of O(N))
            if (this.activeIdx !== null && this.words[this.activeIdx]) {
                this.words[this.activeIdx].classList.remove('active-word');
            }
            if ((this.isChromeWindows || this.isChromeAndroid) && this.activeParagraph) {
                this.activeParagraph.classList.remove('chrome-paragraph-active');
                this.activeParagraph = null;
            }

            this.activeIdx = index;
            const el = this.words[index];
            if (el) {
                if (!(this.isChromeWindows || this.isChromeAndroid)) {
                    el.classList.add('active-word');
                }

                if (this.isChromeWindows || this.isChromeAndroid) {
                    const paragraph = el.closest('p');
                    if (paragraph) {
                        paragraph.classList.add('chrome-paragraph-active');
                        this.activeParagraph = paragraph;
                    }
                }

                // Throttle scrollIntoView to keep Chrome responsive on long chapters
                if (this.isPlaying) {
                    const now = Date.now();
                    if (now - this.lastScrollAt > 250) {
                        this.lastScrollAt = now;
                        el.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    }
                }
            }
        }

        jumpTo(index) {
            const wasPlaying = this.isPlaying;
            this.stop();
            this.pointer = index;
            this.highlight(index);
            if (wasPlaying) this.play();
        }

        play() {
            if (this.isPaused) {
                this.synth.resume();
                this.isPaused = false;
                this.updateUI(true);

                // If the current voice doesn't emit boundary events, restart the fallback highlighter
                if (this.boundaryEventsSeen === 0 && this.currentChunkIndices) {
                    this.scheduleFallbackHighlighter(this.currentChunkIndices);
                }
                return;
            }

            if (this.pointer >= this.words.length) return;

            this.stop();
            this.updateUI(true);
            this.speakFromPointer();
        }

        speakFromPointer() {
            let currentText = "";
            let chunkIndices = [];
            
            for (let i = this.pointer; i < this.words.length; i++) {
                currentText += this.words[i].textContent + " ";
                chunkIndices.push(i);
                if (chunkIndices.length >= 60) break;
                if (currentText.length > 350) break;
                if (currentText.length > 200 && /[.!?\n]/.test(this.words[i].textContent)) break;
            }

            if (!currentText.trim()) return;

            this.utterance = new SpeechSynthesisUtterance(currentText);
            const selectedVoice = this.synth.getVoices().find(v => v.name === this.selectedVoiceName);
            if (selectedVoice) this.utterance.voice = selectedVoice;
            this.utterance.rate = parseFloat(this.speedSlider.value) || 1;
            this.utterance.lang = (selectedVoice && selectedVoice.lang) ? selectedVoice.lang : 'en-US';

            // Track chunk for fallback/highlight resume
            this.currentChunkIndices = chunkIndices;
            this.androidWordPointer = 0;
            this.boundaryEventsSeen = 0;
            this.clearFallbackTimers();

            this.utterance.onstart = () => {
                // Highlight immediately at start
                this.highlight(this.pointer);

                // If no boundary events arrive (common for some Chrome voices), start a timing-based fallback
                this.scheduleFallbackHighlighter(chunkIndices);
            };

            this.utterance.onboundary = (event) => {
                if (typeof event.charIndex !== 'number') return;

                this.boundaryEventsSeen++;

                if (this.boundaryEventsSeen == 1) {
                    // Real boundary events are flowing → stop any fallback timers
                    this.clearFallbackTimers();
                }

                // Map character index back to our word indices
                const charIdx = event.charIndex;
                let currentPos = 0;
                for (let i = 0; i < chunkIndices.length; i++) {
                    const wordLen = this.words[chunkIndices[i]].textContent.length + 1;
                    if (charIdx >= currentPos && charIdx < currentPos + wordLen) {
                        const newPointer = chunkIndices[i];
                        if (newPointer !== this.pointer) {
                            this.pointer = newPointer;
                            window.requestAnimationFrame(() => this.highlight(this.pointer));
                        }
                        break;
                    }
                    currentPos += wordLen;
                }
            };

            this.utterance.onend = () => {
                if (this.isPlaying) {
                    // Ensure the pointer advances to the end of this chunk even if no boundary events fired
                    const lastWordInChunk = chunkIndices[chunkIndices.length - 1];
                    if (typeof lastWordInChunk === 'number' && this.pointer < lastWordInChunk) {
                        this.pointer = lastWordInChunk;
                    }

                    this.pointer++;
                    if (this.pointer < this.words.length) {
                        this.speakFromPointer();
                    } else {
                        this.stop();
                    }
                }
            };

            this.synth.speak(this.utterance);
            
            // Pre-load next chunk (Logic check: Web Speech doesn't expose buffer, 
            // but we can prepare the next string/object)
            this.prepareNextChunk();
        }

        prepareNextChunk() {
            // Identify where the next chunk starts
            let nextStart = this.pointer + 1; 
            // Find end of current chunk to see where next begins
            // (In this simple implementation, speakFromPointer handles continuity)
        }

        clearFallbackTimers() {
            if (this.fallbackGuardTimer) {
                clearTimeout(this.fallbackGuardTimer);
                this.fallbackGuardTimer = null;
            }
            if (this.fallbackTimers && this.fallbackTimers.length) {
                this.fallbackTimers.forEach(id => clearTimeout(id));
                this.fallbackTimers = [];
            }
        }

        scheduleFallbackHighlighter(chunkIndices) {
            // Guard: only start fallback if boundary events aren't coming
            this.clearFallbackTimers();
            this.fallbackGuardTimer = window.setTimeout(() => {
                if (!this.isPlaying || this.isPaused) return;
                if (this.boundaryEventsSeen > 0) return;
                this.startFallbackHighlighter(chunkIndices);
            }, 800);
        }

        startFallbackHighlighter(chunkIndices) {
            // Timing-based (approx.) highlighting for voices that don't emit word boundaries
            const baseWpm = 180;
            const rate = parseFloat(this.speedSlider?.value) || 1;
            const startPos = Math.max(0, chunkIndices.indexOf(this.pointer));
            let t = 0;

            for (let j = startPos; j < chunkIndices.length; j++) {
                const wordIndex = chunkIndices[j];
                const w = this.words[wordIndex];
                const wordLen = (w && w.textContent) ? w.textContent.length : 1;
                const weight = Math.min(1.8, Math.max(0.7, wordLen / 5));
                const ms = Math.max(120, (60000 / (baseWpm * rate)) * weight);
                t += ms;

                const id = window.setTimeout(() => {
                    if (!this.isPlaying || this.isPaused) return;
                    this.pointer = wordIndex;
                    this.highlight(wordIndex);
                }, t);
                this.fallbackTimers.push(id);
            }
        }


        pause() {
            this.synth.pause();
            this.isPaused = true;
            this.clearFallbackTimers();
            this.updateUI(false);
        }

        stop() {
            this.clearFallbackTimers();
            this.synth.cancel();
            this.isPlaying = false;
            this.isPaused = false;
            this.updateUI(false);
        }

        restart() {
            this.stop();
            this.pointer = 0;
            this.words.forEach(w => w.classList.remove('active-word'));
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }
    }

    const celestialVoice = new CelestialVoice();

    // --- 8. CLEANUP ENGINE ---
    function cleanupReader() {
        // Stop all speech synthesis immediately
        if ('speechSynthesis' in window) {
            window.speechSynthesis.cancel();
        }

        if (celestialVoice) {
            celestialVoice.stop();
        }
        
        // Only exit fullscreen if we are actually in it
        if (document.fullscreenElement) {
            document.exitFullscreen().catch(() => {});
        }
        
        // Restore UI visibility
        toggleUI(true);
    }

    // Listen for every possible way to leave the page
    window.addEventListener('beforeunload', cleanupReader);
    window.addEventListener('pagehide', cleanupReader);
    document.addEventListener('visibilitychange', () => {
        if (document.visibilityState === 'hidden') cleanupReader();
    });
    document.addEventListener('astro:before-preparation', cleanupReader);
  }
  initReader();
  document.addEventListener('astro:page-load', initReader);
</script>

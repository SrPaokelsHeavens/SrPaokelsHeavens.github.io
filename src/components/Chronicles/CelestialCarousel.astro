---
interface Props {
  events: any[];
}

const { events } = Astro.props;
---

<div class="celestial-carousel-system relative w-full pt-0 pb-10 group">
  
  <!-- Side Glows -->
  <div class="absolute left-0 top-0 w-32 h-full bg-gradient-to-r from-void via-void/40 to-transparent z-20 pointer-events-none"></div>
  <div class="absolute right-0 top-0 w-32 h-full bg-gradient-to-l from-void via-void/40 to-transparent z-20 pointer-events-none"></div>

  <!-- Desktop Chevron Controls -->
  <button type="button" class="carousel-chevron carousel-chevron--left" data-carousel-prev aria-label="Previous slide">
    <svg viewBox="0 0 24 48" aria-hidden="true" focusable="false">
      <path d="M19 3L6 24L19 45" />
    </svg>
  </button>
  <button type="button" class="carousel-chevron carousel-chevron--right" data-carousel-next aria-label="Next slide">
    <svg viewBox="0 0 24 48" aria-hidden="true" focusable="false">
      <path d="M5 3L18 24L5 45" />
    </svg>
  </button>

  <!-- Embla Viewport -->
  <div class="embla overflow-hidden" id="embla-viewport">
    <div class="embla__container flex">
      {events.map((event, index) => (
        <div class="embla__slide flex-[0_0_100%] md:flex-[0_0_85%] lg:flex-[0_0_75%] min-w-0 px-4">
          <div class="celestial-card relative h-[400px] md:h-[500px] overflow-hidden border border-gold/10 group/card transition-all duration-700">
            
            <!-- Background Image with Overlay -->
            <div class="absolute inset-0 z-0">
                <img 
                    src={event.image || (event.type === 'chapter' ? 'https://images.unsplash.com/photo-1519681393784-d120267933ba?q=80&w=1000' : 'https://images.unsplash.com/photo-1478720568477-152d9b164e26?q=80&w=1000')} 
                    alt={event.title}
                    loading={index === 0 ? 'eager' : 'lazy'}
                    fetchpriority={index === 0 ? 'high' : 'auto'}
                    decoding="async"
                    class="w-full h-full object-cover transition-transform duration-[2000ms] group-hover/card:scale-110"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-void via-void/60 to-transparent"></div>
            </div>

            <!-- Content -->
            <div class="absolute inset-0 z-10 p-8 flex flex-col justify-end">
                <div class="mb-4 flex items-center gap-3">
                    <span class="px-3 py-1 bg-gold text-void text-[10px] font-bold uppercase tracking-widest">
                        {event.badge || event.category || event.type}
                    </span>
                    <span class="text-gold/60 text-[10px] uppercase tracking-[0.3em]">
                        {event.metadata.date}
                    </span>
                </div>
                
                <h3 class="text-3xl md:text-5xl font-serif text-white mb-4 leading-tight">
                    {event.title}
                </h3>
                
                <p class="text-[#D1D1C7]/70 text-sm md:text-base max-w-2xl line-clamp-2 italic mb-8">
                    {event.excerpt || 'The annals of the heavens have been updated with new chronicles.'}
                </p>

                <a href={event.url} class="inline-block w-fit text-xs text-gold border border-gold/40 px-8 py-3 hover:bg-gold hover:text-void transition-all uppercase tracking-[0.2em] font-bold">
                    Examine Record →
                </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <div class="carousel-dots" aria-label="Carousel pagination">
    {events.map((_, index) => (
      <button
        type="button"
        class={`carousel-dot ${index === 0 ? 'is-active' : ''}`}
        data-carousel-dot
        data-index={index}
        aria-label={`Go to slide ${index + 1}`}
      ></button>
    ))}
  </div>
</div>

<style>
  .celestial-carousel-system {
    --chevron-color: rgba(197, 160, 89, 0.45);
    --chevron-color-active: rgba(197, 160, 89, 0.8);
  }

  .embla__slide {
    perspective: 1000px;
  }
  
  .celestial-card {
    box-shadow: 0 20px 50px rgba(0,0,0,0.5);
    opacity: 0.4;
    transform: scale(0.9) translateY(20px);
    filter: grayscale(0.5) blur(2px);
  }

  /* Embla high-level state is handled via JS classes */
  .celestial-card.is-selected {
    opacity: 1;
    transform: scale(1) translateY(0);
    filter: grayscale(0) blur(0);
    border-color: rgba(197, 160, 89, 0.6);
    box-shadow: 0 0 40px rgba(197, 160, 89, 0.15);
  }

  .carousel-dots {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    margin-top: 1.25rem;
  }

  .carousel-dot {
    width: 8px;
    height: 8px;
    border-radius: 9999px;
    border: 1px solid rgba(197, 160, 89, 0.5);
    background: rgba(197, 160, 89, 0.12);
    box-shadow: 0 0 12px rgba(197, 160, 89, 0.1);
    transition: all 250ms ease;
  }

  .carousel-dot.is-active {
    width: 18px;
    background: rgba(197, 160, 89, 0.75);
    box-shadow: 0 0 14px rgba(197, 160, 89, 0.35);
  }

  .carousel-chevron {
    position: absolute;
    top: 50%;
    z-index: 30;
    transform: translateY(-50%);
    border: 1px solid rgba(197, 160, 89, 0.2);
    border-radius: 9999px;
    width: 44px;
    height: 44px;
    display: none;
    align-items: center;
    justify-content: center;
    background: rgba(8, 8, 12, 0.45);
    backdrop-filter: blur(4px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 220ms ease, border-color 220ms ease, background-color 220ms ease;
  }

  .carousel-chevron svg {
    width: 16px;
    height: 30px;
  }

  .carousel-chevron path {
    fill: none;
    stroke: var(--chevron-color);
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
    transition: stroke 220ms ease;
  }

  .carousel-chevron--left {
    left: 2.25rem;
  }

  .carousel-chevron--right {
    right: 2.25rem;
  }

  @media (hover: hover) and (pointer: fine) {
    .carousel-chevron {
      display: inline-flex;
    }

    .celestial-carousel-system:hover .carousel-chevron,
    .carousel-chevron:focus-visible {
      opacity: 1;
      pointer-events: auto;
    }

    .carousel-chevron:hover {
      border-color: rgba(197, 160, 89, 0.45);
      background: rgba(8, 8, 12, 0.58);
    }

    .carousel-chevron:hover path,
    .carousel-chevron:focus-visible path {
      stroke: var(--chevron-color-active);
    }
  }
</style>

<script>
  import EmblaCarousel from 'embla-carousel'
  import Autoplay from 'embla-carousel-autoplay'

  function setupCarousel() {
    const root = document.querySelector('.celestial-carousel-system');
    if (!root) return;
    if (root.getAttribute('data-carousel-ready') === 'true') return;

    const viewportNode = root.querySelector('#embla-viewport');
    if (!viewportNode) return;

    const options = { 
        loop: true, 
        align: 'center',
        skipSnaps: false,
        duration: 30
    };
    
    const autoplayOptions = {
        delay: 5000,
        stopOnInteraction: false,
        stopOnMouseEnter: true
    };
    const autoplay = Autoplay(autoplayOptions);
    
    const emblaApi = EmblaCarousel(viewportNode as HTMLElement, options, [autoplay]);
    const prevButton = root.querySelector('[data-carousel-prev]') as HTMLButtonElement | null;
    const nextButton = root.querySelector('[data-carousel-next]') as HTMLButtonElement | null;
    const dotButtons = Array.from(root.querySelectorAll('[data-carousel-dot]')) as HTMLButtonElement[];

    const updateFocus = () => {
        const slides = emblaApi.slideNodes();
        const selectedIndex = emblaApi.selectedScrollSnap();
        
        // Embla handles loops by cycling indices, but slideNodes 
        // provides the physical elements.
        slides.forEach((slide, index) => {
            const card = slide.querySelector('.celestial-card');
            if (card) {
                if (index === selectedIndex) {
                    card.classList.add('is-selected');
                } else {
                    card.classList.remove('is-selected');
                }
            }
        });

        dotButtons.forEach((dot, index) => {
            if (index === selectedIndex) {
                dot.classList.add('is-active');
                dot.setAttribute('aria-current', 'true');
            } else {
                dot.classList.remove('is-active');
                dot.removeAttribute('aria-current');
            }
        });
    };

    const navigate = (action: () => void) => {
        action();
        autoplay.reset();
    };

    prevButton?.addEventListener('click', () => navigate(() => emblaApi.scrollPrev()));
    nextButton?.addEventListener('click', () => navigate(() => emblaApi.scrollNext()));
    dotButtons.forEach((dot, index) => {
        dot.addEventListener('click', () => navigate(() => emblaApi.scrollTo(index)));
    });

    emblaApi.on('select', updateFocus);
    emblaApi.on('init', updateFocus);
    emblaApi.on('reInit', updateFocus);
    root.setAttribute('data-carousel-ready', 'true');
    updateFocus();
  }

  // Support for Astro View Transitions
  setupCarousel();
  document.addEventListener('astro:page-load', setupCarousel);
</script>

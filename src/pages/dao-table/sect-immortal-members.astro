---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const tierOrder = [
  'Celestial Body Refining Realm',
  'Celestial Foundation Realm',
  'Celestial Core Realm',
  'Celestial Soul Realm',
  'Celestial Transformation Realm',
  'Celestial Sovereign Realm',
];

const tierEntries = await getCollection('daoTiers');
const tierImages = new Map(tierEntries.map((entry) => [entry.data.tier, entry.data.image]));

const members = await getCollection('sectMembers');

const tierBenefits = new Map([
  [
    'Celestial Body Refining Realm',
    'Initiates who keep the braziers lit earn early whispers from the scriptorium and shelter within the Hidden Annex.',
  ],
  [
    'Celestial Foundation Realm',
    'Bridge Wardens steady every release cycle and are entrusted with sealed tomes pulled straight from the presses.',
  ],
  [
    'Celestial Core Realm',
    'Formation archivists receive experimental manuscripts and assist in weaving the sect’s deeper systems.',
  ],
  [
    'Celestial Soul Realm',
    'Continuity keepers commune with the Heavenly Reader and can request echoes of long-lost sagas.',
  ],
  [
    'Celestial Transformation Realm',
    'Thunder envoys fund metamorphic projects—closed trials, cross-realm voyages, and other ambitious rites.',
  ],
  [
    'Celestial Sovereign Realm',
    'Sovereign patrons steward pavilion expansions, ceremonial regalia, and whatever new wonders the sect prototypes.',
  ],
]);

const tierGroups = tierOrder.map((tier) => {
  const people = members
    .filter((member) => member.data.tier === tier)
    .sort((a, b) => (a.data.alias || '').localeCompare(b.data.alias || ''))
    .map((entry) => ({
      alias: entry.data.alias,
      epithet: entry.data.epithet,
      focus: entry.data.focus,
      since: entry.data.since,
      roleplay: entry.body?.trim(),
      image: tierImages.get(tier),
    }));

  return {
    tier,
    benefits: tierBenefits.get(tier),
    entries: people,
  };
});
---

<BaseLayout title="Sect Immortal Members" description="Monthly supporters sorted by cultivation tier.">
  <section class="py-20">
    <div class="container mx-auto px-4 max-w-3xl text-center">
      <p class="text-[10px] tracking-[0.35em] uppercase text-gold/70 mb-4">Recurring Patrons</p>
      <h1 class="text-4xl font-serif text-gold tracking-[0.2em] uppercase mb-4">Sect Immortal Members</h1>
      <p class="text-sm text-[#d1d1c7]/70">These pledges are the lifeblood of the Sect: incense for the ancestor tablets, spirit stones for the scribes, and quiet wards that let new chronicles bloom. Add or remove members by updating the Dao Table markdown scrolls whenever the ledger needs to be refreshed.</p>
    </div>
  </section>

  <section class="container mx-auto px-4 pb-24 space-y-20">
    {tierGroups.map((group) => (
      <div>
        <div class="text-center mb-8">
          <h2 class="tier-heading text-3xl font-serif text-gold uppercase">{group.tier}</h2>
          {group.benefits && (
            <p class="text-sm text-[#d1d1c7]/70 max-w-2xl mx-auto mt-4">{group.benefits}</p>
          )}
        </div>

        {group.entries.length === 0 ? (
          <div class="border border-dashed border-gold/20 text-center py-12 text-[11px] uppercase tracking-[0.3em] text-gold/40">Awaiting members</div>
        ) : (
          <div class="dao-grid">
            {group.entries.map((member) => (
              <article class="dao-card">
                {member.image && <div class="dao-card__image" style={`background-image: url(${member.image});`}></div>}
                <div class="dao-card__body">
                  <p class="text-[10px] text-gold/60 uppercase tracking-[0.3em] mb-2">{member.focus || 'Sect Member'}</p>
                  <h3 class="text-2xl font-serif text-gold mb-1">{member.alias}</h3>
                  <p class="text-xs text-[#d1d1c7]/60 italic mb-4">{member.epithet || 'Immortal Member'}</p>
                  {member.roleplay && <p class="text-sm text-[#d1d1c7]/70 whitespace-pre-line">{member.roleplay}</p>}
                  <div class="text-[10px] text-gold/40 uppercase tracking-[0.3em] mt-6">{member.since ? `Since ${member.since}` : 'Active'}</div>
                </div>
              </article>
            ))}
          </div>
        )}
      </div>
    ))}
  </section>
</BaseLayout>

<style>
  .tier-heading {
    letter-spacing: 0.3em;
  }

  @media (max-width: 480px) {
    .tier-heading {
      font-size: 1.875rem;
      letter-spacing: 0.15em;
    }
  }

  .dao-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .dao-card {
    position: relative;
    border: 1px solid rgba(197, 160, 89, 0.2);
    background: rgba(5, 5, 5, 0.85);
    min-height: 260px;
    overflow: hidden;
  }

  .dao-card__image {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0.1;
  }

  .dao-card__body {
    position: relative;
    padding: 1.75rem;
  }
</style>

